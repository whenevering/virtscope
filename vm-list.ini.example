# VirtScope 端点配置示例
#
# 用法：
#   1. 将本文件复制为 vm-list.ini
#   2. 按下面的格式为每个 vCenter / ESXi 增加一个 [section]
#   3. section 名是显示用的标识，不要重复
#
# ⚠️ 该文件含明文凭据，已在 .gitignore 中排除，请勿提交到仓库。

[vcenter-prod]
host = vcenter.example.com
username = readonly@vsphere.local
password = change-me
port = 443

[vcenter-dr]
host = vcenter-dr.example.com
username = readonly@vsphere.local
password = change-me
port = 443

[esxi-edge-01]
host = 10.0.0.11
username = root
password = change-me
port = 443
